# MongoDB Atlas connection string
# Get this from Atlas -> Database -> Connect -> Drivers
# Replace <username>, <password>, and <dbname>
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/skillforge?retryWrites=true&w=majority

# Any long random string - used to sign JWTs. Generate one with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

# How long a login session lasts
JWT_EXPIRES_IN=30d

# Port the API server runs on
PORT=5000

# Your deployed/local frontend URL (for CORS). For local dev this is Vite's default.
CLIENT_URL=http://localhost:5173

# Used once by the seed script to create your first admin account
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@skillforge.com
ADMIN_PASSWORD=ChangeThisPassword123
